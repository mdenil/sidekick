# Sidekick environment — copy to .env and fill in.
# Only DEEPGRAM_API_KEY is strictly required; everything else has sensible
# defaults or is only needed for specific backends / features.

# ─── Required ─────────────────────────────────────────────────────────────
# Deepgram key — powers streaming STT (/ws/deepgram), batch STT (/transcribe),
# and Aura TTS (/tts). Sign up at https://console.deepgram.com.
DEEPGRAM_API_KEY=

# ─── Upstream agent ───────────────────────────────────────────────────────
# Sidekick talks to any agent that speaks the abstract agent contract
# (HTTP+SSE — see docs/ABSTRACT_AGENT_PROTOCOL.md). hermes-plugin is the
# typical upstream; the in-tree stub agent under `agent/` is a hermes-
# free reference.
SIDEKICK_PLATFORM_URL=http://127.0.0.1:8645
# Bearer token shared with the upstream. For the hermes path, this is
# `SIDEKICK_PLATFORM_TOKEN` in your `~/.hermes/.env`.
SIDEKICK_PLATFORM_TOKEN=
# Preferred-models filter for the picker. Glob patterns, comma-sep.
# Only models matching these globs show up in Settings → Model.
SIDEKICK_PREFERRED_MODELS=anthropic/*,google/gemini-*,google/gemma-*,openai/gpt-5*,deepseek/*

# ─── Branding / skinning ──────────────────────────────────────────────────
# Display name (browser tab, header, About panel). Default: SideKick
SIDEKICK_APP_NAME=
# Tagline below the app name. Default: Agent Portal
SIDEKICK_APP_SUBTITLE=
# Label used for agent bubbles / lockscreen. Default: Clawdian
SIDEKICK_AGENT_LABEL=
# Optional override for the --primary CSS variable. Any CSS color
# (hex, rgb(), hsl()). Empty = use the stylesheet default (sage).
SIDEKICK_THEME_PRIMARY=

# ─── Optional APIs ────────────────────────────────────────────────────────
# Google/Gemini image generation (/gen-image). App works fine without.
GOOGLE_API_KEY=
# Google Maps Embed API key for map cards.
MAPS_EMBED_KEY=
# OpenRouter key for the model picker (Settings → Model). Picker
# isn't exposed today (BackendAdapter capability `models: false`); set
# this when wiring the picker via the agent contract in a follow-up.
OPENROUTER_API_KEY=

# ─── Ambient widget ───────────────────────────────────────────────────────
# Default coords for the weather widget in the corner.
SIDEKICK_WEATHER_LAT=
SIDEKICK_WEATHER_LON=

# ─── Deepgram keyterm biasing ─────────────────────────────────────────────
# Comma-separated vocabulary hints for streaming STT. Additive to the
# per-install keyterms.txt file (the normal home for these — see README).
SIDEKICK_STT_KEYTERMS=

# ─── Server ───────────────────────────────────────────────────────────────
# Proxy + agent ports. start-all.mjs reads PROXY_PORT (or PORT) and
# AGENT_PORT and shifts the pair forward together (3002/4002, ...) if
# either is busy at boot, so the proxy always finds the agent. Set
# SIDEKICK_PLATFORM_URL above to point at a separate-host agent;
# AGENT_PORT then has no effect.
PROXY_PORT=3001
AGENT_PORT=4001
# HOST=0.0.0.0
# Disable /screenshot endpoint (takes Playwright screenshots for link
# preview cards). Set to any non-empty value to disable.
SIDEKICK_DISABLE_SCREENSHOT=
