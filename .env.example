# Sidekick environment — copy to .env. Out of the box, ZERO env vars
# are required: `npm start` boots the in-tree stub agent (echo LLM)
# and serves the PWA on http://localhost:3001. Add a Deepgram key
# below to enable voice (STT + Aura TTS); everything else is optional.

# ─── Voice (Deepgram) ─────────────────────────────────────────────────────
# Deepgram key — powers streaming STT (/ws/deepgram), batch STT
# (/transcribe), and Aura TTS (/tts). Sign up at
# https://console.deepgram.com. Without this, voice features are off
# but typed chat still works.
DEEPGRAM_API_KEY=

# ─── Upstream agent (override only if NOT using the bundled stub) ─────────
# Sidekick speaks the OpenAI Responses API (HTTP+SSE — see
# docs/ABSTRACT_AGENT_PROTOCOL.md). By default, `npm start` spawns
# the in-tree stub agent at backends/stub/ on port 4001 and points
# the proxy at it automatically. Uncomment the line below ONLY to
# point at a different upstream (Hermes, OpenRouter, LMStudio, your
# own /v1/responses-speaking server).
# SIDEKICK_PLATFORM_URL=http://127.0.0.1:8645
# Bearer token shared with the upstream. Required by the Hermes
# plugin (matches `SIDEKICK_PLATFORM_TOKEN` in `~/.hermes/.env`),
# optional for the bundled stub.
# SIDEKICK_PLATFORM_TOKEN=
# Preferred-models filter for the picker. Glob patterns, comma-sep.
# Only models matching these globs show up in Settings → Model.
# SIDEKICK_PREFERRED_MODELS=anthropic/*,google/gemini-*,google/gemma-*,openai/gpt-5*,deepseek/*

# ─── Branding / skinning ──────────────────────────────────────────────────
# Display name (browser tab, header, About panel). Default: Sidekick
SIDEKICK_APP_NAME=
# Tagline below the app name. Default: Agent Portal
SIDEKICK_APP_SUBTITLE=
# Label used for agent bubbles / lockscreen. Default: Clawdian
SIDEKICK_AGENT_LABEL=
# Optional override for the --primary CSS variable. Any CSS color
# (hex, rgb(), hsl()). Empty = use the stylesheet default (sage).
SIDEKICK_THEME_PRIMARY=

# ─── Optional APIs ────────────────────────────────────────────────────────
# Google/Gemini image generation (/gen-image). App works fine without.
GOOGLE_API_KEY=
# Google Maps Embed API key for map cards.
MAPS_EMBED_KEY=
# OpenRouter key for the model picker (Settings → Model) on backends
# that surface model lists via the agent contract.
OPENROUTER_API_KEY=

# ─── Ambient widget ───────────────────────────────────────────────────────
# Default coords for the weather widget in the corner.
SIDEKICK_WEATHER_LAT=
SIDEKICK_WEATHER_LON=

# ─── Deepgram keyterm biasing ─────────────────────────────────────────────
# Comma-separated vocabulary hints for streaming STT. Additive to the
# per-install keyterms.txt file.
SIDEKICK_STT_KEYTERMS=

# ─── Server ───────────────────────────────────────────────────────────────
# Proxy + agent ports. start-all.mjs reads PROXY_PORT (or PORT) and
# AGENT_PORT and shifts the pair forward together (3002/4002, ...) if
# either is busy at boot, so the proxy always finds the agent.
PROXY_PORT=3001
AGENT_PORT=4001
# HOST=0.0.0.0
# Disable /screenshot endpoint (takes Playwright screenshots for link
# preview cards). Set to any non-empty value to disable.
SIDEKICK_DISABLE_SCREENSHOT=
