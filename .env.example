# Sidekick environment — copy to .env and fill in.
# `npm start` runs without ANY of these set: it uses the in-tree stub
# agent (echo LLM) and a no-op TTS path. Add the optional keys when
# you want voice + cards + a real LLM.

# ─── Upstream agent ───────────────────────────────────────────────────────
# Where the proxy reaches the agent. Defaults to the in-tree stub on
# 127.0.0.1:4001 (boots automatically via `npm start`). Point at a
# hermes-plugin install or any /v1/*-speaking server to swap.
SIDEKICK_PLATFORM_URL=http://127.0.0.1:4001
# Bearer token shared with the upstream. Stub agent runs in open mode
# (no token required) by default; hermes-plugin uses
# `SIDEKICK_PLATFORM_TOKEN` from `~/.hermes/.env`.
SIDEKICK_PLATFORM_TOKEN=

# ─── Voice (optional) ─────────────────────────────────────────────────────
# Deepgram key powers streaming STT (live mic via WebRTC) and Aura TTS.
# Without it, sidekick is text-only. Sign up at https://console.deepgram.com.
DEEPGRAM_API_KEY=

# ─── Other optional integrations ──────────────────────────────────────────
# Google Gemini for /gen-image (in-chat image generation cards).
GOOGLE_API_KEY=
# Google Maps Embed key for map cards.
MAPS_EMBED_KEY=
# OpenRouter key — Settings → Model picker uses it to enumerate
# available LLMs (model-picker is dormant until wired through the
# agent contract; safe to leave blank for now).
OPENROUTER_API_KEY=
# Preferred-models filter for the picker. Comma-separated globs;
# only matching models show up in Settings → Model.
SIDEKICK_PREFERRED_MODELS=anthropic/*,google/gemini-*,google/gemma-*,openai/gpt-5*,deepseek/*

# ─── Branding / skinning ──────────────────────────────────────────────────
# Defaults: SIDEKICK_APP_NAME=SideKick, SIDEKICK_APP_SUBTITLE="Agent Portal",
# SIDEKICK_AGENT_LABEL=Clawdian. Override per-deployment.
SIDEKICK_APP_NAME=
SIDEKICK_APP_SUBTITLE=
SIDEKICK_AGENT_LABEL=
# Optional --primary CSS variable override. Any CSS color.
SIDEKICK_THEME_PRIMARY=

# ─── Ambient widget (optional) ────────────────────────────────────────────
SIDEKICK_WEATHER_LAT=
SIDEKICK_WEATHER_LON=

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3001
# HOST=127.0.0.1 (default). 0.0.0.0 to bind all interfaces.
# SIDEKICK_DISABLE_SCREENSHOT=1 disables the /screenshot endpoint
# (used for link-preview cards). Skip if Playwright Chromium isn't
# available.
