From 3da164e78a5598fcbc6eaee46f490f39f09c3917 Mon Sep 17 00:00:00 2001
From: Sidekick <noreply@example.invalid>
Date: Fri, 8 May 2026 18:05:43 +0100
Subject: [PATCH] local: register Platform.SIDEKICK + adapter factory branch

Adds Platform.SIDEKICK enum + _create_adapter factory branch that imports
SidekickAdapter from the hermes-agent plugin namespace
(hermes_plugins.sidekick). Plugin source lives in the sidekick repo at
backends/hermes/plugin/__init__.py and is installed by the user as a
symlink to ~/.hermes/plugins/sidekick.

Also adds:
- _apply_env_overrides reads SIDEKICK_PLATFORM_TOKEN to enable the
  platform when the token is set.
- platform_env_map / platform_allow_all_map entries for the standard
  allowlist plumbing (SIDEKICK_PLATFORM_ALLOWED_USERS /
  SIDEKICK_PLATFORM_ALLOW_ALL_USERS).
- hermes_cli/platforms.py registry entry.

Adapted from sidekick repo's 0001-add-sidekick-platform.patch with two
manual fix-ups for context drift in upstream main:
- platform_env_map gained TELEGRAM/QQBOT entries
- hermes_cli platforms list gained ("cron", ...) entry
---
 gateway/config.py       | 10 ++++++++++
 gateway/run.py          | 13 +++++++++++++
 hermes_cli/platforms.py |  1 +
 3 files changed, 24 insertions(+)

diff --git a/gateway/config.py b/gateway/config.py
index 6b09b34d1..daf5f0e69 100644
--- a/gateway/config.py
+++ b/gateway/config.py
@@ -109,6 +109,7 @@ class Platform(Enum):
     BLUEBUBBLES = "bluebubbles"
     QQBOT = "qqbot"
     YUANBAO = "yuanbao"
+    SIDEKICK = "sidekick"
     @classmethod
     def _missing_(cls, value):
         """Accept unknown platform names only for known plugin adapters.
@@ -1704,6 +1705,15 @@ def _apply_env_overrides(config: GatewayConfig) -> None:
         if yuanbao_group_allow_from:
             extra["group_allow_from"] = yuanbao_group_allow_from
 
+    # Sidekick (PWA + audio bridge front-end). Plugin lives at
+    # ~/.hermes/plugins/sidekick/. SIDEKICK_PLATFORM_TOKEN gates startup.
+    sidekick_token = os.getenv("SIDEKICK_PLATFORM_TOKEN")
+    if sidekick_token:
+        if Platform.SIDEKICK not in config.platforms:
+            config.platforms[Platform.SIDEKICK] = PlatformConfig()
+        config.platforms[Platform.SIDEKICK].enabled = True
+        config.platforms[Platform.SIDEKICK].token = sidekick_token
+
     # Session settings
     idle_minutes = os.getenv("SESSION_IDLE_MINUTES")
     if idle_minutes:
diff --git a/gateway/run.py b/gateway/run.py
index 69c8793f2..a0cecd9b6 100644
--- a/gateway/run.py
+++ b/gateway/run.py
@@ -4675,6 +4675,16 @@ class GatewayRunner:
                 return None
             return YuanbaoAdapter(config)
 
+        elif platform == Platform.SIDEKICK:
+            from hermes_plugins.sidekick import (
+                SidekickAdapter,
+                check_sidekick_requirements,
+            )
+            if not check_sidekick_requirements():
+                logger.warning("Sidekick: requirements not met (token missing or aiohttp absent)")
+                return None
+            return SidekickAdapter(config)
+
         return None
     def _is_user_authorized(self, source: SessionSource) -> bool:
         """
@@ -4717,6 +4727,7 @@ class GatewayRunner:
             Platform.BLUEBUBBLES: "BLUEBUBBLES_ALLOWED_USERS",
             Platform.QQBOT: "QQ_ALLOWED_USERS",
             Platform.YUANBAO: "YUANBAO_ALLOWED_USERS",
+            Platform.SIDEKICK: "SIDEKICK_PLATFORM_ALLOWED_USERS",
         }
         platform_group_user_env_map = {
             Platform.TELEGRAM: "TELEGRAM_GROUP_ALLOWED_USERS",
@@ -4743,6 +4754,7 @@ class GatewayRunner:
             Platform.BLUEBUBBLES: "BLUEBUBBLES_ALLOW_ALL_USERS",
             Platform.QQBOT: "QQ_ALLOW_ALL_USERS",
             Platform.YUANBAO: "YUANBAO_ALLOW_ALL_USERS",
+            Platform.SIDEKICK: "SIDEKICK_PLATFORM_ALLOW_ALL_USERS",
         }
         # Bots admitted by {PLATFORM}_ALLOW_BOTS bypass the human allowlist (#4466).
         platform_allow_bots_map = {
@@ -4928,6 +4940,7 @@ class GatewayRunner:
                 Platform.WEIXIN:   "WEIXIN_ALLOWED_USERS",
                 Platform.BLUEBUBBLES: "BLUEBUBBLES_ALLOWED_USERS",
                 Platform.QQBOT:    "QQ_ALLOWED_USERS",
+                Platform.SIDEKICK: "SIDEKICK_PLATFORM_ALLOWED_USERS",
             }
             platform_group_env_map = {
                 Platform.TELEGRAM: (
diff --git a/hermes_cli/platforms.py b/hermes_cli/platforms.py
index e341b734e..3665cda82 100644
--- a/hermes_cli/platforms.py
+++ b/hermes_cli/platforms.py
@@ -40,6 +40,7 @@ PLATFORMS: OrderedDict[str, PlatformInfo] = OrderedDict([
     ("webhook",        PlatformInfo(label="🔗 Webhook",         default_toolset="hermes-webhook")),
     ("api_server",     PlatformInfo(label="🌐 API Server",      default_toolset="hermes-api-server")),
     ("cron",           PlatformInfo(label="⏰ Cron",            default_toolset="hermes-cron")),
+    ("sidekick",       PlatformInfo(label="🎙️ Sidekick",        default_toolset="hermes-cli")),
 ])
 
 
