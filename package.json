{
  "name": "clawportal",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Voice-first PWA frontend for OpenClaw — streaming speech-to-text, Deepgram Aura TTS, inline card renderers, and a pocket-lock overlay for mobile use.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/jscholz/clawportal",
  "repository": {
    "type": "git",
    "url": "https://github.com/jscholz/clawportal.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "start": "npm run build && node --experimental-strip-types --disable-warning=ExperimentalWarning server.ts",
    "start:dev": "node scripts/build.mjs --watch & node --experimental-strip-types --disable-warning=ExperimentalWarning --watch server.ts",
    "test": "node --test --experimental-strip-types --disable-warning=ExperimentalWarning test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "playwright-core": "^1.59.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
