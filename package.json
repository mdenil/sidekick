{
  "name": "sidekick",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Voice-first PWA frontend for OpenClaw — streaming speech-to-text, Deepgram Aura TTS, inline card renderers, and a pocket-lock overlay for mobile use.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/jscholz/sidekick",
  "repository": {
    "type": "git",
    "url": "https://github.com/jscholz/sidekick.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "start": "npm run build && node --experimental-strip-types --disable-warning=ExperimentalWarning server.ts",
    "start:dev": "node scripts/build.mjs --watch & node --experimental-strip-types --disable-warning=ExperimentalWarning --watch server.ts",
    "test": "node --test --experimental-strip-types --disable-warning=ExperimentalWarning 'test/**/*.test.ts' 'src/**/*.test.ts' 'proxy/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/run-smoke.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1",
    "onnxruntime-web": "^1.25.1",
    "playwright-core": "^1.59.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
