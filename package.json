{
  "name": "sidekick",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Voice-first PWA frontend for any /v1/*-speaking agent backend. Streaming STT, Aura TTS, inline cards, pocket-lock for mobile use.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/jscholz/sidekick",
  "repository": {
    "type": "git",
    "url": "https://github.com/jscholz/sidekick.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "start": "node scripts/start-all.mjs",
    "start:proxy": "npm run build && node --experimental-strip-types --disable-warning=ExperimentalWarning server.ts",
    "start:agent": "cd agent && npm start",
    "start:dev": "node scripts/build.mjs --watch & node --experimental-strip-types --disable-warning=ExperimentalWarning --watch server.ts",
    "test": "node --test --experimental-strip-types --disable-warning=ExperimentalWarning 'test/**/*.test.ts' 'src/**/*.test.ts' 'server-lib/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/run-smoke.mjs"
  },
  "dependencies": {
    "playwright-core": "^1.59.1",
    "ws": "^8.20.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
